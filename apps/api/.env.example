# ─── Core (no keys needed) ────────────────────────────────
FASTF1_CACHE_DIR=./cache
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── AI Insights & Chat (Claude) ─────────────────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Voice Commentary (ElevenLabs TTS) ───────────────────
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ─── Live F1 Data (RapidAPI) ─────────────────────────────
# Get key: https://rapidapi.com/hub — subscribe to an F1 live data API
RAPIDAPI_KEY=
LIVE_MODE_ENABLED=false
